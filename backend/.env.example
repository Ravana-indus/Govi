# ── Core ──────────────────────────────────────────────────────────────────
APP_ENV=dev
API_PREFIX=/v1
DEFAULT_LANGUAGE=si

# ── Data stores ───────────────────────────────────────────────────────────
# Dev default (keyless): SQLite + in-memory cache.
DATABASE_URL=sqlite:///./farmingos.db
# Prod: postgresql+psycopg2://farmingos:secret@db:5432/farmingos
# REDIS_URL=redis://redis:6379/0

# ── Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=dev-secret-change-me
ACCESS_TOKEN_TTL_MIN=30
REFRESH_TOKEN_TTL_DAYS=30
EXPOSE_OTP_IN_DEV=true

# ── Model gateway (mock = zero external keys) ──────────────────────────────
MODEL_PROVIDER=mock        # mock | openai | anthropic | gemini
VISION_PROVIDER=mock
ASR_PROVIDER=mock
TTS_PROVIDER=mock
EMBED_PROVIDER=mock
# LLM_API_KEY=

# ── Object storage (prod) ──────────────────────────────────────────────────
# S3_ENDPOINT=http://minio:9000
# S3_BUCKET=farmingos-media
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# ── Channels (Phase 3) ─────────────────────────────────────────────────────
# WHATSAPP_TOKEN=
# WHATSAPP_VERIFY_TOKEN=
# WA_PHONE_ID=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_MODE=poll        # poll | webhook

# ── Agent tuning / guardrails ──────────────────────────────────────────────
PRICE_NEAREST_MARKETS=3
PRICE_STALE_DAYS=3
PRICE_TRANSPORT_LKR_PER_KM=0.3
CROP_CONFIDENCE_THRESHOLD=0.6
