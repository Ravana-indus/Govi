# Production env template. Copy to .env and fill real values. NEVER commit secrets.
APP_ENV=prod
API_PREFIX=/v1
DEFAULT_LANGUAGE=si

# Data stores (managed)
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/farmingos
REDIS_URL=redis://HOST:6379/0

# Auth — generate a strong (32+ char) secret
JWT_SECRET=__set_a_strong_random_secret__
EXPOSE_OTP_IN_DEV=false

# Security
CORS_ORIGINS=https://app.farmingos.lk     # comma-separated; never "*" in prod

# Model providers (swap mock -> real to go live)
MODEL_PROVIDER=mock
# LLM_API_KEY=
# VISION_PROVIDER=  ASR_PROVIDER=  TTS_PROVIDER=

# Object storage (signed URLs for crop images / voice notes)
S3_ENDPOINT=
S3_BUCKET=farmingos-media
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Channels
WHATSAPP_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=        # enables X-Hub-Signature-256 verification
WA_PHONE_ID=
TELEGRAM_BOT_TOKEN=
TELEGRAM_MODE=webhook

# SMS gateway (OTP delivery) — wire your local aggregator
# SMS_GATEWAY_KEY=
